---
// Button.astro
// Renders <a> if href is provided, <button> otherwise.
// Accepts variant, class passthrough, and additional HTML attributes.
interface Props {
  variant?: 'primary' | 'secondary';
  href?: string;
  class?: string;
  [key: string]: unknown;
}

const {
  variant = 'primary',
  href,
  class: className,
  ...rest
} = Astro.props as Props;

const Tag = href ? 'a' : 'button';
const classes = ['btn', `btn--${variant}`, className].filter(Boolean).join(' ');
---

<Tag href={href || undefined} class={classes} {...rest}>
  <slot />
</Tag>

<style>
  /* ================================================================
     .btn — Base button
     ================================================================ */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2xs);
    padding: 0.625rem 1.5rem;
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    letter-spacing: 0.01em;
    border-radius: 10px;
    cursor: pointer;
    white-space: nowrap;
    text-decoration: none;
    position: relative;
    transition: background var(--duration-base) var(--ease-out-quart),
                color var(--duration-fast) var(--ease-out-quart),
                border-color var(--duration-fast) var(--ease-out-quart),
                box-shadow var(--duration-fast) var(--ease-out-quart),
                transform var(--duration-fast) var(--ease-out-quart);
  }

  .btn:active {
    transform: scale(0.97) !important;
  }

  .btn:focus-visible {
    outline: var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }

  /* ================================================================
     .btn--primary — Warm earth gradient, 3D volume
     Pairs with .btn--secondary: same warmth, lift, and family.
     No overlays — clean fill counterpart to the ghost variant.
     ================================================================ */

  .btn--primary {
    color: var(--color-surface);
    background: linear-gradient(
      180deg,
      oklch(0.64 0.12 44) 0%,
      oklch(0.58 0.13 42) 20%,
      oklch(0.52 0.14 40) 45%,
      oklch(0.46 0.15 37) 70%,
      oklch(0.40 0.16 34) 100%
    );
    border: none;
    box-shadow:
      inset 0 1px 0 oklch(1 0 0 / 0.10),
      inset 0 -2px 3px oklch(0 0 0 / 0.20),
      0 1px 3px oklch(0 0 0 / 0.12),
      0 5px 12px oklch(0.50 0.12 38 / 0.25),
      0 10px 30px oklch(0.50 0.12 38 / 0.10);
  }

  .btn--primary:hover {
    background: linear-gradient(
      180deg,
      oklch(0.67 0.12 45) 0%,
      oklch(0.61 0.13 43) 20%,
      oklch(0.55 0.14 41) 45%,
      oklch(0.49 0.15 38) 70%,
      oklch(0.43 0.16 35) 100%
    );
    box-shadow:
      inset 0 1px 0 oklch(1 0 0 / 0.12),
      inset 0 -2px 3px oklch(0 0 0 / 0.22),
      0 3px 8px oklch(0 0 0 / 0.15),
      0 8px 20px oklch(0.50 0.12 38 / 0.30),
      0 12px 40px oklch(0.50 0.12 38 / 0.15);
    transform: translateY(-2px);
  }

  .btn--primary:active {
    box-shadow:
      inset 0 1px 0 oklch(1 0 0 / 0.08),
      inset 0 -1px 2px oklch(0 0 0 / 0.25),
      0 1px 2px oklch(0 0 0 / 0.10);
    transform: translateY(0);
  }

  /* ================================================================
     .btn--secondary — Ghost button, etched warmth
     Pairs with .btn--primary: same 38° hue family, same lift on
     hover.  Color and border are overridable via CSS custom props
     for contextual theming (e.g. dark backgrounds).
     ================================================================ */

  .btn--secondary {
    color: var(--btn-secondary-color, oklch(0.50 0.12 38));
    background: var(--btn-secondary-bg, oklch(0.55 0.08 38 / 0.04));
    border: 1.5px solid var(--btn-secondary-border, oklch(0.50 0.12 38 / 0.30));
  }

  .btn--secondary:hover {
    color: var(--btn-secondary-color, oklch(0.50 0.12 38));
    background: var(--btn-secondary-hover-bg, oklch(0.50 0.10 38 / 0.10));
    border-color: var(--btn-secondary-hover-border, oklch(0.50 0.12 38 / 0.50));
    box-shadow: var(--btn-secondary-hover-shadow, 0 3px 8px oklch(0 0 0 / 0.08), 0 6px 16px oklch(0.50 0.10 38 / 0.12));
    transform: translateY(-2px);
  }

  .btn--secondary:active {
    color: var(--btn-secondary-color, oklch(0.50 0.12 38));
    box-shadow: none;
    transform: translateY(0);
  }
</style>
