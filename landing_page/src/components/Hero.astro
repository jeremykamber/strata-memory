---
import Button from './Button.astro';
import Terminal from './Terminal.astro';

const demoLines = [
  // ── Command 1: init ───────────────────────────────────
  { text: 'strata init --project my-agent', type: 'prompt' as const },
  { text: '  Creating memory strata for my-agent...', type: 'output' as const },
  { text: '  ✓ Active stratum initialized  (retention: 48h)', type: 'highlight' as const },
  { text: '  ✓ Cooled stratum configured   (retention: 14d)', type: 'highlight' as const },
  { text: '  ✓ Archive stratum ready       (retention: 90d)', type: 'highlight' as const },
  { text: '  → Zero LLM calls used for memory management', type: 'highlight' as const },
  // ── Command 2: add a memory ────────────────────────────
  { text: 'strata add projects/llm-research.md "# Transformer attention patterns 2026"', type: 'prompt' as const },
  { text: '  ✓ Written to active/projects/llm-research.md', type: 'highlight' as const },
  { text: '  → Auto-tagged with decay: 30d', type: 'output' as const },
  // ── Command 3: search ──────────────────────────────────
  { text: 'strata search "transformer attention"', type: 'prompt' as const },
  { text: '  ┌─────────────────────────────────────────────────────┐', type: 'output' as const, delay: 60 },
  { text: '  │ 1. active/projects/llm-research.md                 │', type: 'highlight' as const, delay: 80 },
  { text: '  │    Created 2026-06-08  |  Decay: 30d                │', type: 'output' as const, delay: 60 },
  { text: '  │ 2. cooled/memory/architecture/transformer-basics.md │', type: 'highlight' as const, delay: 80 },
  { text: '  │    Created 2026-04-12  |  Decay: 60d                │', type: 'output' as const, delay: 60 },
  { text: '  │ 3. archive/research/attention-is-all-you-need.json  │', type: 'highlight' as const, delay: 80 },
  { text: '  │    Archived 2026-02-20  |  FTS5-indexed             │', type: 'output' as const, delay: 60 },
  { text: '  └─────────────────────────────────────────────────────┘', type: 'output' as const, delay: 60 },
  { text: '  → Found 3 results across 3 strata', type: 'highlight' as const },
  // ── Command 4: status ─────────────────────────────────
  { text: 'strata status', type: 'prompt' as const },
  { text: '  Layer       Files     Oldest      Retention', type: 'output' as const, delay: 100 },
  { text: '  active/     42        2h ago      48h       ', type: 'highlight' as const, delay: 120 },
  { text: '  cooled/     156       14d ago     14d       ', type: 'highlight' as const, delay: 120 },
  { text: '  archive/    2,103     90d ago     —         ', type: 'highlight' as const, delay: 120 },
];
---

<section class="hero" aria-label="Introduction">
  <div class="hero__inner">
    <!-- ── Left column: content ── -->
    <div class="hero-content">
        <h1 class="hero-heading">Finally, agent memory that models how <em>we think</em>.</h1>

      <p class="hero-subtitle">
      An open-source, three-tier memory architecture that automatically degrades and archives old agent context. You get the benefits of llm-wiki, a vector DB, AND cold storage.
      </p>

      <div class="hero-install">
        <div class="install-card">
          <code class="install-card__code">
            <span class="install-prompt" aria-hidden="true">$</span>
            <span>pip install git+https://github.com/jeremykamber/strata-memory.git</span>
          </code>
          <button class="install-card__copy" type="button" aria-label="Copy install command">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <rect x="4" y="4" width="10" height="10" rx="1.5" stroke="currentColor" stroke-width="1.2"/>
              <path d="M12 4V2.5A1.5 1.5 0 0 0 10.5 1h-8A1.5 1.5 0 0 0 1 2.5v8A1.5 1.5 0 0 0 2.5 12H4" stroke="currentColor" stroke-width="1.2"/>
            </svg>
          </button>
        </div>
      </div>

      <div class="hero-actions">
        <Button variant="primary" href="https://github.com/jeremykamber/strata-memory" target="_blank" rel="noopener noreferrer">
          View on GitHub
        </Button>
        <Button variant="secondary" href="https://jeremykamber.substack.com/p/strata-memory-system" target="_blank" rel="noopener noreferrer">
          Read the Philosophy
        </Button>
      </div>

    </div>

    <!-- ── Right column: animated terminal demo ── -->
    <div class="hero-visual" aria-hidden="true">
      <div class="hero-terminal">
        <span class="hero-terminal__label">Live demo</span>
        <Terminal lines={demoLines} title="strata init" />
      </div>
    </div>
  </div>
</section>

<style>
  /* ==================================================================
     Hero — Two-column layout with floating geological stratum slabs
     ================================================================== */

  /* ---- Outer section ---- */
  .hero {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    padding: var(--space-2xl) var(--space-lg);
    position: relative;
  }

  .hero__inner {
    display: flex;
    gap: var(--space-2xl);
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  /* ---- Left column: content ---- */
  .hero-content {
    flex: 0 1 540px;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .hero-heading {
    font-family: var(--font-display);
    font-size: var(--text-display);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--color-text-primary);
    text-wrap: balance;
    animation: hero-fade-up var(--duration-entrance) var(--ease-out-quart) both;
    animation-delay: 0ms;
  }

  .hero-subtitle {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 65ch;
    margin-bottom: 0;
    animation: hero-fade-up var(--duration-entrance) var(--ease-out-quart) both;
    animation-delay: 150ms;
  }

  /* ---- Install card ---- */
  .hero-install {
    animation: hero-fade-up var(--duration-entrance) var(--ease-out-quart) both;
    animation-delay: 300ms;
  }

  .install-card {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    background: oklch(0.55 0.15 40 / 0.08);
    border: 1px solid oklch(0.55 0.15 40 / 0.15);
    border-radius: 8px;
    padding: var(--space-xs) var(--space-sm);
  }

  .install-card__code {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-primary);
    line-height: 1.5;
  }

  .install-prompt {
    color: var(--color-accent);
    font-weight: 600;
    user-select: none;
  }

  .install-card__copy {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    border-radius: 4px;
    transition: color var(--duration-fast) var(--ease-out-quart),
                background var(--duration-fast) var(--ease-out-quart);
    flex-shrink: 0;
  }

  .install-card__copy:hover {
    color: var(--color-accent);
    background: oklch(0.55 0.15 40 / 0.1);
  }

  .install-card__copy:active {
    transform: scale(0.95);
  }

  .install-card__copy svg {
    display: block;
  }

  /* ---- Action buttons (GitHub, Philosophy) ---- */
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    max-width: 480px;
    animation: hero-fade-up var(--duration-entrance) var(--ease-out-quart) both;
    animation-delay: 600ms;
  }

  /* ==================================================================
     Right column: animated terminal demo
     ================================================================== */

  .hero-visual {
    flex: 0 1 500px;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    justify-content: flex-start;
    animation: visual-fade-in 0.8s var(--ease-out-quart) both;
    animation-delay: 300ms;
  }

  .hero-terminal {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  .hero-terminal__label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding-left: 2px;
  }

  /* Ensure the terminal component fills available width */
  .hero-terminal .terminal {
    width: 100%;
    max-width: 100%;
  }

  /* ==================================================================
     Entrance keyframes
     ================================================================== */

  @keyframes hero-fade-up {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Fade-in for the visual column */
  @keyframes visual-fade-in {
    from {
      opacity: 0;
      transform: translateX(12px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* ==================================================================
     Reduced motion
     ================================================================== */

  @media (prefers-reduced-motion: reduce) {
    .hero-heading,
    .hero-subtitle,
    .hero-install,
    .hero-cta {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .hero-visual {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  /* ==================================================================
     Responsive
     ================================================================== */

  @media (max-width: 1100px) {
    .hero__inner {
      gap: var(--space-lg);
    }

    .hero-content {
      flex: 0 1 420px;
    }

    .hero-visual {
      flex: 0 1 380px;
    }
  }

  @media (max-width: 820px) {
    .hero__inner {
      flex-direction: column;
      gap: var(--space-lg);
    }

    .hero-visual {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--space-xl) var(--space-md);
      align-items: flex-start;
    }

    .hero-content {
      gap: var(--space-md);
    }

    .hero-subtitle {
      font-size: var(--text-base);
    }

    .hero-actions {
      max-width: 100%;
      flex-direction: column;
    }

    :global(.btn) {
      width: 100%;
      text-align: center;
    }
  }
</style>

<script>
  (function () {
    'use strict';
    var btn = document.querySelector('.install-card__copy');
    if (!btn) return;

    btn.addEventListener('click', async function () {
      var text = 'pip install git+https://github.com/jeremykamber/strata-memory.git';
      try {
        await navigator.clipboard.writeText(text);
        btn.innerHTML =
          '<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">' +
          '<path d="M13 4L6 12L3 9" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>' +
          '</svg>';
        setTimeout(function () {
          btn.innerHTML =
            '<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">' +
            '<rect x="4" y="4" width="10" height="10" rx="1.5" stroke="currentColor" stroke-width="1.2"/>' +
            '<path d="M12 4V2.5A1.5 1.5 0 0 0 10.5 1h-8A1.5 1.5 0 0 0 1 2.5v8A1.5 1.5 0 0 0 2.5 12H4" stroke="currentColor" stroke-width="1.2"/>' +
            '</svg>';
        }, 2000);
      } catch (_) {
        var code = btn.closest('.install-card').querySelector('.install-card__code');
        if (code) {
          var range = document.createRange();
          range.selectNodeContents(code);
          var sel = window.getSelection();
          sel.removeAllRanges();
          sel.addRange(range);
        }
      }
    });
  })();
</script>
