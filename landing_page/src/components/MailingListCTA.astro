---
import Button from './Button.astro';
// MailingListCTA.astro
// Follow Strata development on Substack.
---

<section class="cta section-depth-archive" aria-labelledby="cta-heading">
  <div class="cta__container">
    <span class="cta__label">The philosophy</span>

    <h2 class="cta__heading" id="cta-heading">
      Follow the memory philosophy
    </h2>

    <p class="cta__text">
      Agentic coding, agent memory, and building autonomous systems that
      learn how to forget. Architecture notes, tradeoffs, and what
      I learn along the way.
    </p>

    <Button variant="secondary" href="https://substack.com/@jeremykamber" target="_blank" rel="noopener noreferrer">
      Follow on Substack
    </Button>
  </div>
</section>

<style>
  .cta {
    padding: var(--space-3xl) var(--space-lg);
    border-top: 1px solid oklch(0.40 0.02 48);
    position: relative;
  }

  .cta__label {
    display: inline-block;
    margin-bottom: var(--space-2xs);
    color: var(--color-text-secondary-on-dark);
  }

  .cta__heading {
    margin-bottom: var(--space-sm);
    color: var(--color-text-on-dark);
  }

  .cta__text {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: 1.65;
    color: var(--color-text-secondary-on-dark);
    margin: 0 auto var(--space-lg);
    max-width: 48ch;
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .cta {
      padding: var(--space-2xl) var(--space-md);
    }

    .cta__text {
      font-size: var(--text-base);
    }

    :global(.btn.btn--secondary) {
      width: 100%;
    }
  }


</style>
