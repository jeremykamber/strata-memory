---
// DocsLayout.astro
// Sidebar + content layout for the Strata documentation site.
// Uses the same design tokens as the landing page (global.css).
// Warm earth tones, restrained color, geological precision.

import '../styles/global.css';
import Navbar from '../components/Navbar.astro';

export interface Props {
  title: string;
  slug: string;
}

const { title, slug } = Astro.props;

const nav: { category: string; items: { slug: string; title: string }[] }[] = [
  {
    category: "Getting Started",
    items: [
      { slug: "index", title: "Overview" },
      { slug: "installation", title: "Installation" },
    ],
  },
  {
    category: "Core Concepts",
    items: [
      { slug: "architecture", title: "Architecture" },
      { slug: "configuration", title: "Configuration" },
      { slug: "search", title: "Search" },
      { slug: "tracking", title: "Tracking" },
    ],
  },
  {
    category: "CLI & Integration",
    items: [
      { slug: "cli-reference", title: "CLI Reference" },
      { slug: "pi-integration", title: "Pi Integration" },
      { slug: "how_to_make_pi_extension", title: "Pi Extension Guide" },
    ],
  },
  {
    category: "Reference",
    items: [
      { slug: "philosophy-mapping", title: "Philosophy Mapping" },
      { slug: "strata_blog_post", title: "Blog Post" },
    ],
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} &mdash; Strata Docs</title>
    <meta name="description" content={"Strata documentation - " + title} />
    <meta name="theme-color" content="#f0e6d8" />
    <link rel="canonical" href={"https://strata.sh/docs/" + slug + "/"} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;800&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,500;0,8..60,600;1,8..60,400&display=swap" />
  </head>
  <body>
    <div class="docs-root">
      <Navbar hideCta />

      <aside class="docs-sidebar">
        <nav class="docs-nav">
          {
            nav.map((group) => (
              <div class="docs-nav-group">
                <h3 class="docs-nav-category">{group.category}</h3>
                <ul class="docs-nav-list">
                  {group.items.map((item) => {
                    const href = item.slug === "index" ? "/docs/" : `/docs/${item.slug}/`;
                    return (
                      <li>
                        <a
                          href={href}
                          class:list={[
                            "docs-nav-link",
                            { "docs-nav-link--active": slug === item.slug },
                          ]}
                        >
                          {item.title}
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            ))
          }
        </nav>
      </aside>

      <div class="docs-content-wrapper">
        <main class="docs-content">
          <article>
            <slot />
          </article>
        </main>

        <footer class="docs-footer">
          <div class="docs-footer-inner">
            <a href="/" class="docs-footer-link">&larr; Back to landing</a>
            <span class="docs-footer-sep" aria-hidden="true">/</span>
            <a href="https://github.com/jeremykamber/strata-memory" class="docs-footer-link">GitHub</a>
          </div>
        </footer>
      </div>
    </div>
  </body>
</html>

<style>
  .docs-root {
    display: flex;
    flex-wrap: wrap;
    min-height: 100vh;
    padding-top: 3.5rem;
    background: var(--color-bg);
    color: var(--color-text-primary);
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.7;
  }

  /* ---------- Sidebar ---------- */
  .docs-sidebar {
    position: sticky;
    top: 3.5rem;
    width: 270px;
    height: calc(100vh - 3.5rem);
    overflow-y: auto;
    flex-shrink: 0;
    background: var(--depth-active);
    padding: var(--space-xl) var(--space-md);
  }

  .docs-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .docs-nav-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .docs-nav-category {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin: 0;
    padding: 0 0.75rem 0.25rem;
  }

  .docs-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .docs-nav-link {
    display: block;
    padding: 0.375rem 0.75rem;
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: 4px;
    transition: background var(--duration-fast) var(--ease-out-quart),
                color var(--duration-fast) var(--ease-out-quart);
  }

  .docs-nav-link:hover {
    color: var(--color-accent);
    background: var(--color-surface-raised);
  }

  .docs-nav-link--active {
    color: var(--color-accent);
    background: var(--color-surface);
    font-weight: 600;
  }

  .docs-nav-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* ---------- Content ---------- */
  .docs-content-wrapper {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .docs-footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-md) var(--space-2xl);
  }

  .docs-footer-inner {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    max-width: 760px;
  }

  .docs-footer-link {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-quart);
  }

  .docs-footer-link:hover {
    color: var(--color-accent);
  }

  .docs-footer-sep {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    user-select: none;
  }

  @media (max-width: 900px) {
    .docs-sidebar {
      width: 220px;
      padding: var(--space-lg) var(--space-sm);
    }
  }

  @media (max-width: 768px) {
    .docs-root {
      flex-direction: column;
    }

    .docs-sidebar {
      position: static;
      width: 100%;
      height: auto;
      padding: var(--space-md);
    }

    .docs-content {
      padding: var(--space-md);
    }

    .docs-footer {
      padding: var(--space-md);
    }
  }
</style>
